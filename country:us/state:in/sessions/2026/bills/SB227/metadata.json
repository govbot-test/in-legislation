{
  "legislative_session": "2026",
  "identifier": "SB 227",
  "title": "Counter action against unmanned aircraft systems (UAS).",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Indiana State Police (ISP)",
    "CITIES; Indianapolis",
    "FEDERAL GOVERNMENT; Generally",
    "HOMELAND SECURITY; Generally",
    "LAW ENFORCEMENT; Academy and Training",
    "LAW ENFORCEMENT; Generally",
    "STATE ELECTED OFFICIALS; Governor",
    "STATE GOVERNMENT; Administrative Code",
    "TECHNOLOGY; Artificial Intelligence and Robotics",
    "TRANSPORTATION; Aircraft"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that the state police department is the statewide coordinating agency for counter-UAS activities authorized under federal law. Provides that the bill's provisions apply: (1) if a federal law is enacted that authorizes state or local law enforcement personnel to detect, track, identify, or mitigate a UAS under federal approval, certification, or oversight; and (2) after the governor publishes a notice in the Indiana Register that includes a description of the authorization and identifies the federal statute or program that provides the authorization. Provides that the state police department may designate a law enforcement agency of a political subdivision as a participating agency if the agency satisfies federal requirements for personnel training and operational readiness. Provides that the state police department may designate Indianapolis as a pilot project location due to the concentration of high-risk sites and special event assessment rating events. Provides that mitigation activities may not be performed unless expressly authorized under federal law."
    }
  ],

  "identifier": "HB 1182",
  "title": "Digital sexual image abuse.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CRIMINAL LAW AND PROCEDURE; Creation of New Offenses",
    "CRIMINAL LAW AND PROCEDURE; Sex Offenses",
    "TECHNOLOGY; Artificial Intelligence and Robotics",
    "TECHNOLOGY; Computers, Cell Phones, and Devices"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Defines \"digital sexual image\" as a digital, computer generated image or video that is created or modified to depict: (1) sexual intercourse; (2) other sexual conduct; or (3) exhibition of certain body parts; of a quality, characteristic, or condition, such that it appears to depict an individual. Establishes the offenses of possession of a digital sexual image and distribution of a digital sexual image."
    }
  ],

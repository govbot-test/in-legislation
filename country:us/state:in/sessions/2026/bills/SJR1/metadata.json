{
  "legislative_session": "2026",
  "identifier": "SJR 1",
  "title": "Constitutional amendment concerning bail.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "COURTS; Bail and Bail Bondsmen",
    "CRIMINAL LAW AND PROCEDURE; Rules of Trial Procedure",
    "STATE GOVERNMENT; Constitution"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that an offense other than murder or treason is not bailable if: (1) the proof is evident or the presumption strong; and (2) the state proves by clear and convincing evidence that no release conditions will reasonably protect the safety of any other person or the community. This proposed amendment has been agreed to by one general assembly."
    }
  ],

  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that unless expressly authorized by another statute, a municipality or county may not adopt, enforce, or maintain an ordinance, order, or rule regulating conduct in a field of regulation that is occupied by a provision in specified titles of the Indiana Code. Establishes a cause of action for a person who has sustained an injury in fact, actual or threatened, from a municipal or county ordinance, order, or rule adopted or enforced by a municipality or county."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "HB 1348",
  "title": "Regulation of grease control equipment.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ADMINISTRATIVE LAW; Generally",
    "UTILITIES; Municipal Utilities",
    "UTILITIES; Water"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Establishes a statewide regulatory scheme for grease control equipment. Provides that a waste water treatment plant must continue to accept septage under certain circumstances. Creates a process for septage haulers to resolve disputes with wastewater treatment plants with respect to accepting septage."
    }
  ],

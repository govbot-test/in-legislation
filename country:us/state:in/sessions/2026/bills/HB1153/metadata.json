  "identifier": "HB 1153",
  "title": "Auto dealer matters.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Child Services (DCS)",
    "AGENCIES; Department of Revenue (DOR)",
    "BOARDS, COMMISSIONS, AND COUNCILS; Newly Created",
    "CIVIL LAW AND PROCEDURE; Liens and Encumbrances",
    "MARRIAGE AND FAMILY LAW; Child Support, Custody, and Visitation",
    "STATE ELECTED OFFICIALS; Secretary of State",
    "STATE GOVERNMENT; Contracts, Procurements, and Purchases",
    "TRANSPORTATION; Dealers and Manufacturers",
    "TRANSPORTATION; Licenses, Plates, Registration, and Titles"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires a dealer to collect and retain certain identifying information from a potential purchaser. Beginning July 1, 2026, requires a transport operator to either: (1) have an established place of business with a physical Indiana address; or (2) provide the secretary of state (secretary) with proof of the transport operator's valid registration from the United States Department of Transportation authorizing the transport operator to operate within Indiana; to apply for a registration number. Provides that a dealership that operates without a license from the secretary commits a Class A infraction."
    }
  ],

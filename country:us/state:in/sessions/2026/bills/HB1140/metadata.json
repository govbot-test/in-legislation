{
  "legislative_session": "2026",
  "identifier": "HB 1140",
  "title": "Sale and resale of event tickets.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "RECREATION AND ENTERTAINMENT",
    "TRADE REGULATIONS; Consumer Credit and Consumer Protection (Including the Uniform Consumer Credit Code (UCCC))"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that certain actions taken by a ticket issuer or ticket reseller with respect to tickets sold or resold for entertainment events constitute deceptive acts. Establishes requirements for the advertising and offer for sale, sale, and resale of tickets. Requires a ticket reseller to issue a refund to a consumer for a ticket if the entertainment event is canceled or if, for certain reasons, the ticket is not accepted by the venue."
    }
  ],

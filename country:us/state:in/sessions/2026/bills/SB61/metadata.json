  "identifier": "SB 61",
  "title": "Information and disclosures concerning radon.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Health (IDOH)",
    "CIVIL LAW AND PROCEDURE; Contracts and Legal Documents",
    "ENVIRONMENT; Pollution (Excluding Air and Water)",
    "PROPERTY; Housing",
    "PROPERTY; Real Estate",
    "REAL ESTATE APPRAISERS, BROKERS, AND SALESPERSONS"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Establishes that, before signing a purchase agreement to sell or transfer residential property, an individual or entity issued a broker's real estate license by the Indiana real estate commission representing a seller shall ensure that the seller: (1) provides a radon warning statement to the buyer; (2) discloses in writing to the buyer any knowledge the seller has of radon concentrations in the dwelling; and (3) provides the buyer with a guide on radon, testing, and mitigation published by the Indiana department of health."
    }
  ],

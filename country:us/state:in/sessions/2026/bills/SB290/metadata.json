  "legislative_session": "2026",
  "identifier": "SB 290",
  "title": "Sex with a minor.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CHILDREN AND MINORS; Crimes Against Children",
    "CRIMINAL LAW AND PROCEDURE; Sex Offenses"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Adds the criminal offense of sex with a minor, which is committed when a person who is at least: (1) 24 years of age and who engages in sexual intercourse or other sexual conduct, fondling, or touching with a child who is 16 years of age; or (2) 25 years of age and who engages in sexual intercourse or other sexual conduct, fondling, or touching with a child who is 16 or 17 years of age. Makes conforming amendments."
    }
  ],

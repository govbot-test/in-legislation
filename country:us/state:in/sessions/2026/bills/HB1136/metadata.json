  "legislative_session": "2026",
  "identifier": "HB 1136",
  "title": "Tuition caps.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Commission for Higher Education (CHE)",
    "HIGHER EDUCATION; Financial Assistance (Including Student Assistance, Loans, Grants, and FAFSA)",
    "PENSIONS AND RETIREMENT BENEFITS; Public Retirement System (INPRS)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that the commission for higher education shall determine a tuition rate and mandatory fee cost of living adjustment for specified postsecondary educational institutions. Requires that, except for cost of living adjustments, the tuition rate and mandatory fees at specified postsecondary educational institutions may not increase from the time the student initially enrolls until the student graduates for an undergraduate student who is an Indiana resident."
    }
  ],

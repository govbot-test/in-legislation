{
  "legislative_session": "2026",
  "identifier": "SB 267",
  "title": "Influence campaign reports.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ELECTIONS; Campaign Activities (Including Advertisements, Contributions, Expenditures, and Reporting)",
    "GENERAL ASSEMBLY; Lobbying and Lobbyists"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires a person who provides another person with at least $500 in compensation to induce, support, aid, or otherwise encourage the other person to engage in an influence campaign to file a written report with the Indiana lobby registration commission. Specifies items that the report must include. Requires subsequent reporting."
    }
  ],

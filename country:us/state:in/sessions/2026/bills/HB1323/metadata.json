{
  "legislative_session": "2026",
  "identifier": "HB 1323",
  "title": "Bail.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CORRECTIONS; Community Corrections",
    "COURTS; Bail and Bail Bondsmen",
    "COURTS; Generally",
    "CRIMINAL LAW AND PROCEDURE; Evidence",
    "CRIMINAL LAW AND PROCEDURE; Offenses Against Persons",
    "PUBLIC DEFENDER; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Prohibits a court from requiring an arrestee to pay bail as a condition of pretrial release, unless: (1) the court finds by clear and convincing evidence that the arrestee is a flight risk or danger to the community; (2) the arrestee is charged with murder or treason; (3) the arrestee is on pretrial release not related to the incident that is the basis for the present arrest; or (4) the arrestee is on probation, parole, or other community supervision. Requires that the amount of bail be the lowest amount required, based on the defendant's financial circumstances, to assure the arrestee's appearance at trial and to protect the community."
    }
  ],

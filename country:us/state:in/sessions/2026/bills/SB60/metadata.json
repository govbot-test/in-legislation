  "identifier": "SB 60",
  "title": "Advanced practice registered nurses.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Professional Licensing Agency (PLA)",
    "HEALTH CARE FACILITIES; Hospitals",
    "HEALTH CARE PROFESSIONALS; Advanced Practice Registered Nurses",

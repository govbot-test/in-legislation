{
  "legislative_session": "2026",
  "identifier": "HB 1125",
  "title": "False or fraudulent deeds and affidavits.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CRIMINAL LAW AND PROCEDURE; Creation of New Offenses",
    "STATE ELECTED OFFICIALS; Attorney General"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that it is a deceptive act enforceable by the attorney general for a person to: (1) convey or attempt to convey; or (2) conspire to convey or attempt to convey; title to real property by recording a false or fraudulent deed or affidavit."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "HB 1137",
  "title": "Foods and beverages on school property.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "SCHOOLS; Funds and Budgets",
    "SCHOOLS; Generally",
    "SCHOOLS; Health and Safety Issues",
    "STATE GOVERNMENT; Federal Funding"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that a public school that participates in a federally funded or assisted meal program: (1) may not serve, sell, or allow a third party vendor to serve or sell a food or beverage that contains certain ingredients on school property on a school day; and (2) shall post any breakfast or lunch menu and ingredients on the school's website. Establishes exceptions."
    }
  ],

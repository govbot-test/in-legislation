  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that the department of child services (department) shall disclose to the public certain information regarding child fatalities or near fatalities. Provides that, upon request, the department may provide additional information regarding cases of child fatalities or near fatalities subject to certain requirements. Makes technical and conforming changes."
    }
  ],

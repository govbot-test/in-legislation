{
  "legislative_session": "2026",
  "identifier": "HB 1022",
  "title": "Selection of candidate for lieutenant governor.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ELECTIONS; Candidates"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires a candidate for governor who has been nominated at a primary election or state convention to certify the name of the candidate for lieutenant governor who will run jointly with the candidate for governor at the general election. Requires the candidate for lieutenant governor to file a declaration of candidacy not later than noon July 15 before the general election. Makes conforming changes."
    }
  ],

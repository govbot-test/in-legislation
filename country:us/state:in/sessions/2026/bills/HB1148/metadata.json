{
  "legislative_session": "2026",
  "identifier": "HB 1148",
  "title": "Same day voter registration.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ELECTIONS; Voter Identification",
    "ELECTIONS; Voter Registration"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Permits an individual to register at the polls by completing a voter registration form and by providing proof of residence. Specifies that an individual may comply with the proof of residence requirement only by providing a REAL ID driver's license or identification card that shows the name and residence address of the individual registering to vote. Requires the ballot of a voter who registers at the polls to be treated as a provisional ballot."
    }
  ],

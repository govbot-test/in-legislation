  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires a party to a protective order proceeding to inform the court of any military protective orders issued by a military commander in effect between the parties. Allows a party to file a military protective order as evidence in a protective order proceeding and provides that the court may issue an ex parte protective order based upon this evidence."
    }
  ],

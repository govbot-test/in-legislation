  ],
  "subject": [
    "AGENCIES; Department of Environmental Management (IDEM)",
    "ENVIRONMENT; Hazardous Waste",
    "FEDERAL GOVERNMENT; Generally",
    "STATE GOVERNMENT; Administrative Code"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Defines \"decision\", \"PFAS chemicals\", and \"state prioritized PFAS chemicals\". Prohibits the department of environmental management (department) from basing a decision primarily on federal risk values that have not been promulgated through federal rulemaking. Instructs the department to avoid the use of federal risk values that are at or below background concentrations in air, water, soil, or sediment. Provides that the department shall focus on state prioritized PFAS chemicals when PFAS chemicals are relevant to carrying out the department's duties."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "HB 1254",
  "title": "Various dental matters; respiratory care.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Professional Licensing Agency (PLA)",
    "HEALTH CARE PROFESSIONALS; Dentistry",
    "HEALTH CARE PROFESSIONALS; Licensing (Including Behavioral and Mental Health)",
    "HEALTH; Dental and Vision"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Amends the educational requirements for dental hygienists. Amends the requirements for administration of nitrous oxide by a dental hygienist. Allows the state board of dentistry to establish additional requirements for an applicant who has failed the licensure examination at least three times. Amends the licensure and temporary permit requirements for respiratory care practitioners."
    }
  ],

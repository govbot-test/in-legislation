  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Expands the Indiana fair housing statute to prohibit discrimination on the basis of a person's: (1) source of income; (2) military active duty status; or (3) veteran status. Defines \"source of income\", \"active duty\", and \"veteran\" for purposes of the statute."
    }

  "legislative_session": "2026",
  "identifier": "HB 1082",
  "title": "Shared labor to conduct referendum.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ELECTIONS; Public Questions and Referendums",
    "HIGHER EDUCATION; Generally",
    "SCHOOLS; Charter Schools",
    "TAXES; Tax Levies"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that a charter school that will participate in an operating referendum tax levy or school safety referendum tax levy must contribute a proportionate share of the labor (in addition to the cost under current law) to conduct the referendum based on the total combined average daily membership of the school corporation and any participating charter schools."
    }
  ],

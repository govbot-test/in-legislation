  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that a person who knowingly or intentionally violates a specified provision by commingling the funds of a committee with the personal funds of an officer, a member, or an associate of the committee commits a Class A misdemeanor. Enhances the penalty to a Level 6 felony if a person commingles at least $50,000 of committee funds."
    }
  ],

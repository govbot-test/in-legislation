{
  "legislative_session": "2026",
  "identifier": "HB 1429",
  "title": "Appraiser statute of limitations.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CIVIL LAW AND PROCEDURE; Statute of Limitations",
    "REAL ESTATE APPRAISERS, BROKERS, AND SALESPERSONS"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides with regard to an appraisal or appraisal service performed after June 30, 2026, a civil action against a licensed or certified real estate appraiser or registered appraisal management company must be commenced not later than five years after the appraisal service date."
    }
  ],

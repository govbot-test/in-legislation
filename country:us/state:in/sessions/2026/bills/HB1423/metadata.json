{
  "legislative_session": "2026",
  "identifier": "HB 1423",
  "title": "Indianapolis public education corporation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Education (DOE) and Secretary of Education",
    "CITIES; Indianapolis",
    "COUNTIES; Marion",
    "EDUCATION; Generally",
    "EDUCATION; Local School Boards",
    "LOCAL ELECTED OFFICIALS; Auditors",
    "SCHOOLS; Charter Schools",
    "SCHOOLS; Funds and Budgets",
    "SCHOOLS; Generally",

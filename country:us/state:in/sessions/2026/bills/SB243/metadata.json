  "subject": [
    "AGENCIES; Department of Revenue (DOR)",
    "CHILDREN AND MINORS; Adoption",
    "GAMBLING, GAMING, AND WAGERING; Generally",
    "STATE GOVERNMENT; Generally",
    "TAXES; Adjusted Gross Income Taxes",
    "TAXES; Credits",
    "TAXES; Estate and Inheritance Taxes",
    "TAXES; Excise Taxes (Not Including Vehicles)",
    "TAXES; Fuel and Vehicle Taxes",

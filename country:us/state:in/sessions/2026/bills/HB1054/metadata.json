  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Defines \"noncompete agreement\". Provides that a noncompete agreement entered into: (1) on or after April 1, 2026; and (2) between an employer and certain persons in the plumbing trade; is void and unenforceable."
    }
  ],

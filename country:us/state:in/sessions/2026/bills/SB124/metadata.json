  "identifier": "SB 124",
  "title": "Age for compulsory school attendance.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Education (DOE) and Secretary of Education",
    "EDUCATION; Generally",
    "SCHOOLS; Curricula",
    "SCHOOLS; Pre-Kindergarten and Kindergarten"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that a student is bound by compulsory school attendance requirements from the beginning of the fall school term for the school year in which the student is five years of age on August 1 of that school year. (Current law provides that a student is bound by compulsory school attendance requirements from the beginning of the fall school term for the school year in which the student becomes seven years of age.) Makes conforming amendments."
    }
  ],

  ],
  "subject": [
    "AGENCIES; Professional Licensing Agency (PLA)",
    "TAXES; Credits"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides for a nonrefundable apprenticeship tax credit (credit) for an eligible employer. Provides that the amount of the credit is $2,500 for each apprentice employed. Specifies procedures for claiming the credit. Requires a board to issue a license, certificate, registration, or permit to an individual to allow the individual to practice the individual's occupation in Indiana if the individual satisfies certain conditions."
    }
  ],

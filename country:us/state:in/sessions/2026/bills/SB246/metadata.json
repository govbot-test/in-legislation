{
  "legislative_session": "2026",
  "identifier": "SB 246",
  "title": "Redaction of court records.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CHILDREN AND MINORS; Generally",
    "COURTS; Witnesses",
    "CRIMINAL LAW AND PROCEDURE; Victims"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the names and specified other information of child victims, child witnesses, and certain other persons to be redacted in criminal actions. Requires the use of an anonymous designator such as \"Child Witness No. 1\" when redacting a name, and prohibits  redaction that uses the person's initials or that describes the person in terms of a family relationship."
    }
  ],

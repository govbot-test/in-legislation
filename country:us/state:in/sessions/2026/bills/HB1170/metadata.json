  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that, for each school year beginning after June 30, 2027, a school corporation shall, if the school corporation determines that the school corporation cannot establish a minimum salary of $60,000 (instead of $40,000 under current law) for each full-time teacher, comply with certain requirements."
    }
  ],

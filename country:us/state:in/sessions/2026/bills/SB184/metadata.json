  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Phases down in equal reductions over four years the state gross retail tax rate imposed on the sale of the following utility services to a person for domestic consumption: (1) Electrical energy. (2) Natural or artificial gas. (3) Water. (4) Steam. (5) Steam heating service."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "HB 1040",
  "title": "Battery against school and healthcare employees.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Child Services (DCS)",
    "CRIMINAL LAW AND PROCEDURE; Generally",
    "HEALTH CARE PROFESSIONALS; Generally",
    "SCHOOLS; Officers and Employees (Other than Teachers)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Increases the penalty for battery on certain health care employees and school employees. Specifies that the enhancement for battery committed against a department of child services (DCS) employee applies only to those DCS employees whose responsibilities include personally supervising a child or parent, personally providing services to a child or parent, or personally interviewing a child or parent as part of an investigation. Requires the employer of a health care or school employee who is the victim of battery to make a semiannual report to the department of labor concerning workplace batteries."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "HB 1414",
  "title": "Forest management.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Natural Resources (DNR)",
    "CIVIL LAW AND PROCEDURE; Immunity and Exemption from Liability",
    "NATURAL RESOURCES; Forests and Forestry",
    "RECREATION AND ENTERTAINMENT"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the department of natural resources (department) to establish recreational fees for the access and use of state forest land. Provides that the department shall ensure that at all times: (1) 10% of state forest land consists of forests that are 100 years or older; and (2) 10% of state forest land consists of forests that are 20 years or younger. Provides that money in the state forestry fund does not revert to the state general fund. Establishes various restrictions on landowner liability to recreational users."
    }
  ],

  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Specifies that if there is more than one candidate for a school board office within certain designated groups of candidates, the candidates shall appear in a certain order and within the grouping and in alphabetical order according to surname."
    }
  ],

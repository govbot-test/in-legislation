{
  "legislative_session": "2026",
  "identifier": "SB 5",
  "title": "Suspension of permit.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ADMINISTRATIVE LAW; Generally",
    "AGENCIES; Alcohol and Tobacco Commission (ATC)",
    "ALCOHOL AND TOBACCO; Alcohol Products",
    "ALCOHOL AND TOBACCO; Licenses and Permits",
    "CRIMINAL LAW AND PROCEDURE; Generally",
    "CRIMINAL LAW AND PROCEDURE; Illicit Drugs, Substances, and Alcohol Offenses"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows the alcohol and tobacco commission (commission) to refuse to grant or renew or to suspend or revoke a retailer's permit if a licensed premises becomes a public nuisance or the scene of certain acts or prohibited conduct. Allows the chairman of the commission to temporarily suspend an alcoholic beverage retail permit if all of the following apply: (1) The chairman has a reasonable belief that a felony has been committed on the licensed premises. (2) The permit holder failed to take reasonable action to prevent the occurrence of a crime. (3) Multiple crimes or violations have occurred on the licensed premises in the last 12 months. (4) The continued operation of the licensed premises would pose a clear and immediate danger to the safety of the surrounding community or general public. Requires the commission to: (1) provide immediate notice to the permit holder of a factual basis for the suspension and the time and place of a hearing on the suspension; and (2) hold the hearing not later than three business days after the permit is suspended."
    }
  ],

  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Establishes the real property assessment task force (task force) to review issues related to real property assessment in Indiana. Sets forth membership, and requires the task force to issue a report to the general assembly not later than November 1, 2026. Adds representatives with certain categories of expertise to the real property assessment task force."
    }
  ],

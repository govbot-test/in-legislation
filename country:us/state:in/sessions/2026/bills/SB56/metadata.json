  "legislative_session": "2026",
  "identifier": "SB 56",
  "title": "Veterinary licensing.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Professional Licensing Agency (PLA)",
    "ANIMALS; Generally",
    "BOARDS, COMMISSIONS, AND COUNCILS; Generally",
    "VETERINARIANS"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that the board of veterinary medicine may issue a license or registration to a qualified applicant without an examination if the qualified applicant: (1) satisfies the requirements for reciprocity of health care professionals; and (2) otherwise meets the requirements to become a licensed veterinarian or a registered veterinary technician."
    }
  ],

  "identifier": "SB 77",
  "title": "Sale of school buildings.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "COUNTY GOVERNMENT",
    "EDUCATION; Local School Boards",
    "HIGHER EDUCATION; Colleges and Universities (Including Ivy Tech)",

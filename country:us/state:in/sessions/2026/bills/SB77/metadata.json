    "PROPERTY; Real Estate",
    "SCHOOLS; Buildings and Grounds",
    "SCHOOLS; Charter Schools"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that a governing body of a school corporation located in a county with a population of less than 150,000 has one year from the date the governing body determines at a public meeting to cease using a covered school building for classroom instruction on student instructional days to sell the covered school building to a county or municipal government at a mutually agreed upon price before the covered school building must be made available for lease or purchase to a charter school or state educational institution. Makes conforming changes."
    }
  ],

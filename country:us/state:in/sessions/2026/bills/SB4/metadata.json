{
  "legislative_session": "2026",
  "identifier": "SB 4",
  "title": "Various fiscal matters.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; State Budget Agency (SBA)",
    "BOARDS, COMMISSIONS, AND COUNCILS; Budget Committee",
    "BOARDS, COMMISSIONS, AND COUNCILS; Generally",
    "CHILDREN AND MINORS; Child Care Programs",
    "COUNTY GOVERNMENT",
    "COURTS; Generally",
    "GENERAL ASSEMBLY; Budget and Appropriations",
    "GENERAL ASSEMBLY; Legislative Council",
    "GENERAL ASSEMBLY; Legislative Services Agency",
    "HEALTH CARE FACILITIES; Mental Health Facilities",
    "RECREATION AND ENTERTAINMENT",
    "STATE ELECTED OFFICIALS; Governor",
    "TAXES; Credits"

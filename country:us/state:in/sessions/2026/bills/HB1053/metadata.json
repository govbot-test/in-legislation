{
  "legislative_session": "2026",
  "identifier": "HB 1053",
  "title": "Remediation of tax sale parcels.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "BUILDINGS AND BUILDING REGULATIONS",
    "LOCAL ELECTED OFFICIALS; Treasurers",
    "LOCAL GOVERNMENT; Contracts, Procurements, and Purchases",
    "PROPERTY; Generally",
    "TAXES; Tax Sales"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Permits a county treasurer to require purchasers of designated parcels of real property that are: (1) located in a consolidated city; and (2) subject to tax sale, and purchased at or as a separate part of a tax sale; to submit remediation plans describing how the purchasers will bring the parcels of real property into compliance with a building code or ordinance of a consolidated city after the redemption period ends."
    }
  ],

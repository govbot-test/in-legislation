  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Specifies restrictions that apply to wake boarding or wake surfing on a public freshwater lake. Establishes a penalty. Specifies restrictions that apply to wake boarding or wake surfing on a small lake."
    }
  ],

  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Removes language concerning an affidavit from provisions concerning probable cause for battery and domestic battery. Requires a law enforcement officer to provide a victim who requests a protection order with the required forms and appropriate assistance in completing and filing the forms."

  "identifier": "SB 125",
  "title": "Marion County small claims court jurisdiction.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CIVIL LAW AND PROCEDURE; Generally",
    "COUNTIES; Marion",
    "COURTS; Small Claims Courts",
    "PROPERTY; Landlords and Tenants"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the following cases to be filed in a Marion County small claims court: (1) A possessory action between a landlord and a tenant in which the past due rent does not exceed $10,000. (2) An action for the possession of property where the value of the property does not exceed $10,000."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "HB 1400",
  "title": "MEWA for child care facilities.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Insurance (IDOI)",
    "CHILDREN AND MINORS; Child Care Programs",
    "INSURANCE; Health Insurance",
    "SOCIAL SERVICES; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows a group or association of child care facilities to establish a multiple employer welfare arrangement (MEWA). Requires the department of insurance to: (1) create a survey requesting certain information from child care facilities; (2) facilitate communication between child care facilities that express an interest in establishing a MEWA; and (3) advise the child care facilities on best practices for lowering insurance costs. Requires the office of the secretary of family and social services to send a direct link to the survey by electronic mail to each child care facility."
    }
  ],

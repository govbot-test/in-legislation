  "identifier": "HB 1194",
  "title": "Bail matters.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "COURTS; Bail and Bail Bondsmen",
    "CRIMINAL LAW AND PROCEDURE; Evidence"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that offenses other than murder are not bailable if the state proves: (1) by a preponderance of the evidence that the proof is evident or the presumption strong; and (2) by clear and convincing evidence that the arrestee is dangerous and that no conditions of release will reasonably protect the safety of other persons or the community. Establishes procedures for a bail hearing."
    }
  ],

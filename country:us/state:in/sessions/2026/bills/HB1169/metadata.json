  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Beginning in taxable year 2027, increases the credit provided for a contribution to an Indiana529 savings plan against a taxpayer's adjusted gross income from $1,500 to $2,500 (and from $750 to $1,250 in the case of a married individual filing a separate return), subject to other requirements."
    }

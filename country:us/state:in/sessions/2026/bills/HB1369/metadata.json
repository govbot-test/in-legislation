  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Expires various property tax exemptions allowed in current law. Provides that certain property tax abatements may not be granted after December 31, 2030. Authorizes a county fiscal body to adopt an ordinance that exempts certain homesteads owned by an individual who is at least 65 years of age from property taxation. Makes corresponding changes."
    }
  ],

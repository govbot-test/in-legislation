  "subject": [
    "AGENCIES; Utility Regulatory Commission (IURC)",
    "ELECTIONS; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that a commissioner of the Indiana utility regulatory commission (IURC) may serve an additional term as a commissioner only if the commissioner's retention for an additional term is approved by voters at a general election."
    }

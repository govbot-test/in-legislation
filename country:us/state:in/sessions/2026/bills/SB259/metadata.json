{
  "legislative_session": "2026",
  "identifier": "SB 259",
  "title": "Partnership composite returns.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "BUSINESS ORGANIZATIONS AND ASSOCIATIONS; Generally",
    "TAXES; Estate and Inheritance Taxes"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Removes penalty provisions that apply if a pass through entity fails to include in a composite return nonresident partners, nonresident shareholders, or nonresident beneficiaries that do not have distributive share income of greater than $0. Makes conforming changes."
    }
  ],

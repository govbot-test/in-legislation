  "subject": [
    "AGENCIES; Department of Transportation (INDOT)",
    "PROPERTY; Eminent Domain",
    "PROPERTY; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the Indiana department of transportation (department) to make an original offer that is equal to 125% of the fair market value of a property when purchasing the property for a project. Provides that a person having an interest in a property that is damaged as a result of a public use is entitled to bring an inverse condemnation claim."
    }
  ],

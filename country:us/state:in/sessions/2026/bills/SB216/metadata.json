  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that if a unit of local government (unit) provides forgivable loans, the unit must (as a condition of providing forgivable loans) require that a person operating a business on a property may be entitled to compensation for business losses resulting from a condemnation of the property."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "SB 284",
  "title": "Law enforcement civilian oversight boards.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "BOARDS, COMMISSIONS, AND COUNCILS; Generally",
    "LAW ENFORCEMENT; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that any type of law enforcement civilian oversight board or commission or any other entity established by a county, municipality, or township to provide civilian oversight over a law enforcement agency, excluding merit boards and commissions, may operate only in an advisory capacity to the applicable law enforcement agency and does not have binding authority over the law enforcement agency."
    }
  ],

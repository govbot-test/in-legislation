  "identifier": "HB 1087",
  "title": "Overdose reversal medication.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ADDICTION SERVICES; Illicit Drugs, Prescription Drugs, Substances, and Alcohol",

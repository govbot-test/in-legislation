  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that, subject to available funding, the division of mental health and addiction may develop an application to provide funds to a school corporation or school maintained by a school corporation to obtain a federal Food and Drug Administration approved opioid overdose reversal medication. Provides that the state health commissioner shall issue a statewide standing order, prescription, or protocol for a federal Food and Drug Administration approved opioid overdose reversal medication for each public school or school corporation."
    }
  ],

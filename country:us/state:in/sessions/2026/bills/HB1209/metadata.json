  "identifier": "HB 1209",
  "title": "Municipal collection protocols.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; State Board of Accounts (SBOA)",
    "CITIES AND TOWNS; Generally",
    "FINANCIAL SERVICES; Collection Agencies",
    "FINANCIAL SERVICES; Financial Accounts (Not Including State Pensions)",
    "LAW ENFORCEMENT; Municipal"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Effective January 1, 2027, establishes requirements for the provision of invoices and delinquency notices for certain municipal accounts. Requires the state board of accounts to prescribe forms for an invoice and a notice of a delinquent account. Requires municipal officers and employees with oversight responsibilities or access to the municipality's financial payment system to be segregated from the responsibilities of reporting or recording payments received. Requires a municipal officer whose official duties include oversight of reporting, recording, or monitoring of the municipality's accounts to not have access to the officer's own personal account."
    }
  ],

  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires a state employee health plan, policy of accident and sickness insurance, and health maintenance organization contract to provide coverage for doula services. Requires Medicaid pregnancy services to include reimbursement for doula services."

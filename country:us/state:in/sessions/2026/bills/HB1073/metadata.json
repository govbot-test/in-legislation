  "identifier": "HB 1073",
  "title": "Rape kit processing.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Indiana State Police (ISP)",
    "CRIMINAL LAW AND PROCEDURE; Sex Offenses",
    "GENERAL ASSEMBLY; Budget and Appropriations"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the state police department (department) to use part of an appropriation from House Enrolled Act 1001 (2025) to process rape kits and to eliminate the backlog of untested rape kits. Permits the department to issue grants to law enforcement agencies and testing labs to eliminate the backlog of untested rape kits. Requires the department to make a report to the general assembly by October 1, 2027, concerning the status of untested rape kits."
    }
  ],

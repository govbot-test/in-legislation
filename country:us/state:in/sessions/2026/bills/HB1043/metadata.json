  "identifier": "HB 1043",
  "title": "Data center water regulation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Natural Resources (DNR)",
    "NATURAL RESOURCES; Rivers, Streams, and Waterways"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Defines \"data center\". Prohibits a person from operating a data center in Indiana without obtaining a consumption permit from the department of natural resources (department). Sets forth information that must be included in a consumption permit application. Establishes procedures for the department to approve or deny a consumption permit application. Provides that a consumption permit may be transferred under certain circumstances. Provides that a person may consult with the department to assess the viability of a proposed data center with respect to water consumption. Allows the natural resources commission to adopt rules to implement this bill."
    }
  ],

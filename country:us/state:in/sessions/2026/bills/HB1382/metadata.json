{
  "legislative_session": "2026",
  "identifier": "HB 1382",
  "title": "County option gasoline tax.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "COUNTY GOVERNMENT",
    "TAXES; Fuel and Vehicle Taxes"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows a county to adopt an ordinance to impose a county option gasoline tax. Specifies procedures for imposition and collection of the county option gasoline tax. Provides that a county may not concurrently impose a county option gasoline tax and a: (1) county wheel tax; and (2) county vehicle excise tax. Specifies requirements for a municipality within a county that wishes to receive a distribution of revenue from the county option gasoline tax."
    }
  ],

  "legislative_session": "2026",
  "identifier": "SB 147",
  "title": "Transit development district license.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Alcohol and Tobacco Commission (ATC)",
    "ALCOHOL AND TOBACCO; Licenses and Permits",
    "LOCAL GOVERNMENT; Generally",
    "TRANSPORTATION; Railroads, Trains, and Stations"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows the alcohol and tobacco commission to issue new three-way permits: (1) that are not subject to the permit quota; and (2) within a transit development district. Requires the maximum number of new permits issued within a district to be determined by written agreement of the legislative body of the municipality within the district and the northwest Indiana regional development authority board."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "SB 2",
  "title": "Bail procedures.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "COURTS; Bail and Bail Bondsmen",
    "COURTS; Judges",
    "CRIMINAL LAW AND PROCEDURE; Generally",
    "CRIMINAL LAW AND PROCEDURE; Rules of Trial Procedure"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that offenses other than murder are not bailable if the state proves: (1) by a preponderance of the evidence that the proof is evident or the presumption strong; and (2) by clear and convincing evidence that the arrestee is dangerous and that no conditions of release will reasonably protect the safety of other persons or the community. Establishes procedures for a bail hearing. Removes duplicative provisions concerning repeat violent arrestees. Permits a court to retain cash bail for the payment of certain costs without an indigency hearing if the defendant has executed an agreement permitting the court to retain the cash bail for these purposes."
    }
  ],

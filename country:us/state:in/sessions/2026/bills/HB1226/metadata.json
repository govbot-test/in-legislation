{
  "legislative_session": "2026",
  "identifier": "HB 1226",
  "title": "Public purchasing from Indiana businesses.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Generally",
    "BUSINESS ORGANIZATIONS AND ASSOCIATIONS; Generally",
    "LOCAL GOVERNMENT; Contracts, Procurements, and Purchases"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides a price preference to a business that is not an Indiana business but offers to provide supplies manufactured, assembled, or produced in Indiana. Provides that an Indiana business that offers to provide supplies manufactured, assembled, or produced in Indiana is eligible for an additional price preference for a contract awarded by a state agency. (Under current law, the additional price preference applies only when two or more equal bids are submitted.) Provides a 25% price preference for the purchase of flags that are manufactured in the United States."
    }
  ],

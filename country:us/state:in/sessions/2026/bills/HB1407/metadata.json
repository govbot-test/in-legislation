  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows qualified organizations to conduct contest based raffles for charity gaming. Specifies the manner in which contest based raffles must be conducted. Provides that a sport horse competition may be used to determine the winners of a contest based raffle."
    }
  ],

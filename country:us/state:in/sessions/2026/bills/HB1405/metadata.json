  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Establishes the prescription drug assistance program for the elderly (program) to be administered by the division of aging. Sets forth requirements of the program. Establishes the prescription drug assistance program for the elderly fund. Creates a Class A misdemeanor for fraud under the program."
    }

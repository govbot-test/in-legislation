  "identifier": "SB 183",
  "title": "Income tax deduction for health insurance premiums.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "INSURANCE; Health Insurance",
    "TAXES; Adjusted Gross Income Taxes",
    "TAXES; Deductions"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that a taxpayer who is covered by a health insurance plan may deduct from the taxpayer's adjusted gross income an amount equal to the total amount of premiums on the health insurance plan the taxpayer paid for coverage during the taxable year."
    }
  ],

  "identifier": "HB 1233",
  "title": "Masking offenses.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CRIMINAL LAW AND PROCEDURE; Creation of New Offenses",
    "CRIMINAL LAW AND PROCEDURE; Generally",
    "CRIMINAL LAW AND PROCEDURE; Offenses Against Public Health, Order, and Decency"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Makes wearing a mask at a public assembly a Class C misdemeanor, and increases the penalty to a Class A misdemeanor for a second or subsequent offense. Increases the penalty for rioting and disorderly conduct to a Level 6 felony if the offense is committed while wearing a mask."
    }
  ],

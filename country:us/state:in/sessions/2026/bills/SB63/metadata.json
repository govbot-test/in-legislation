  "subject": [
    "AGENCIES; Public Retirement System (INPRS)",
    "PENSIONS AND RETIREMENT BENEFITS; Public Retirement System (INPRS)",
    "PENSIONS AND RETIREMENT BENEFITS; Public Retirement System (INPRS)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides for a thirteenth check in calendar year 2026 for certain members, participants, or beneficiaries of the: (1) Indiana state teachers' retirement fund; (2) Indiana public employees' retirement fund; (3) state excise police, gaming agent, gaming control officer, and conservation enforcement officers' retirement plan; (4) state police pre-1987 benefit system; and (5) state police 1987 benefit system."
    }
  ],

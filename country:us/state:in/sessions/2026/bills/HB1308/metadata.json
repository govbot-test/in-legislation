  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Establishes the Indiana bright start program (program) to support the early learning and child care needs of working families with eligible children. Provides that the office of the secretary of family and social services (office) shall develop and implement the program, and may contract with nonprofit corporations to facilitate the program. Establishes the Indiana bright start program fund. Requires the office, beginning October 1, 2027, to annually submit a report to the governor and legislative council with information concerning the program."
    }
  ],

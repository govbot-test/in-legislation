  "identifier": "HB 1198",
  "title": "Use of public restrooms.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CRIMINAL LAW AND PROCEDURE; Creation of New Offenses"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Makes it a Class B misdemeanor if: (1) a male knowingly or intentionally enters a restroom that is designated to be used only by females; or (2) a female knowingly or intentionally enters a restroom that is designated to be used only by males. Provides certain defenses."
    }

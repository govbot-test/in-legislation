  "identifier": "SB 22",
  "title": "Dissolution of human remains.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Generally",
    "DEATH AND DECEASED; Disposition of Remains",
    "DEATH AND DECEASED; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Expands the definition of \"cremation\" to include alkaline hydrolysis as a means for the dissolution of human remains. Requires the state board of funeral and cemetery service to adopt rules governing the operation of alkaline hydrolysis facilities. Adds alkaline hydrolysis to statutes that allow for burial or cremation. Specifies that a person may request alkaline hydrolysis in statutes that allow for burial or cremation."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "HB 1267",
  "title": "State board of accounts.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; State Board of Accounts (SBOA)",
    "AUDITS AND AUDITORS (Non-Elected)",
    "STATE ELECTED OFFICIALS; Governor"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that the state board of accounts is subject to applicable professional auditing standards. Requires the governor to appoint two deputy examiners, one of whom must be a certified public accountant, and the other of whom must be either a certified public accountant or an attorney licensed in Indiana."
    }
  ],

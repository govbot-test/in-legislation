  "identifier": "HB 1240",
  "title": "Dissolution of human remains.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Professional Licensing Agency (PLA)",
    "DEATH AND DECEASED; Disposition of Remains"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Amends the definition of cremation to include alkaline hydrolysis as a means for the dissolution of human remains. Requires the state board of funeral and cemetery service to adopt rules governing the operation of alkaline hydrolysis facilities. Adds alkaline hydrolysis to statutes that allow for burial or cremation."
    }
  ],

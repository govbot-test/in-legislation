  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that certain restrictions on the local regulation of firearms, ammunition, and firearm accessories may not be construed to prevent a county containing a consolidated city from regulating firearms, ammunition, or firearm accessories in a manner more restrictive than Indiana law if the regulation is recommended by a law enforcement agency that has jurisdiction in the county. Specifies regulations that meet these parameters. Requires compliance with the federal and state constitutions."
    }
  ],

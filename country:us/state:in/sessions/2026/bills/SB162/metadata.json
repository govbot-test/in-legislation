{
  "legislative_session": "2026",
  "identifier": "SB 162",
  "title": "Department of workforce development.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Workforce Development (DWD)",
    "LABOR AND EMPLOYMENT; Collective Bargaining, Benefits, and Wages",
    "LABOR AND EMPLOYMENT; Unemployment",
    "TAXES; Credits",
    "TAXES; Deductions"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Removes vacation pay and sick pay from the definition of \"deductible income\". Amends the definition of \"suitable work\" to apply solely to extended benefit claims. Amends the definition of \"employment\" with respect to certain religious, charitable, or educational organizations. Provides that the department of workforce development may make certain direct deposit disbursements under limited circumstances. Provides that the date a determination of eligibility is sent is prima facie evidence of proper service. Codifies certain administrative rules with respect to benefit payments, the filing of claims, and notice. Removes outdated or expired provisions. Removes references to dependents' allowances for purposes of calculating extended benefits. Provides that an individual who files a disaster unemployment assistance claim may be eligible for additional benefits under certain circumstances. Makes conforming changes."
    }
  ],

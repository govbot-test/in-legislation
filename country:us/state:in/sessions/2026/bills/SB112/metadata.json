{
  "legislative_session": "2026",
  "identifier": "SB 112",
  "title": "Candidacy documents.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CIVIL LAW AND PROCEDURE; Contracts and Legal Documents",
    "ELECTIONS; Candidates",
    "ELECTIONS; Voter Registration"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that when an individual files a notice of withdrawal listing an address different from the address on the individual's voter registration record, the individual's signature on the notice of withdrawal constitutes a request to the county voter registration office that the address on the individual's voter registration record be the same as the address on the notice of withdrawal."
    }
  ],

  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Makes it a Class A misdemeanor if a person operates a massage establishment and knowingly or intentionally employs an individual who: (1) is providing massages; and (2) does not have certain professional liability insurance."
    }

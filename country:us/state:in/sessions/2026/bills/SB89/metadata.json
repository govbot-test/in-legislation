{
  "legislative_session": "2026",
  "identifier": "SB 89",
  "title": "Three-way permits.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Alcohol and Tobacco Commission (ATC)",
    "ALCOHOL AND TOBACCO; Licenses and Permits",
    "COUNTIES; Carroll",
    "COUNTIES; La Porte",
    "COUNTIES; Lake",
    "COUNTIES; Monroe",
    "COUNTIES; Tippecanoe"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides the alcohol and tobacco commission may issue not more than: (1) three new three-way permits to the town of Schererville; (2) three new three-way permits to the city of Lafayette; (3) two new three-way permits to the city of West Lafayette; (4) eight new three-way permits to restaurants located within a transit development district located in the city of Michigan City; (5) two new three-way permits to the city of Delphi; and (6) two new three-way permits to the city of Bloomington."
    }
  ],

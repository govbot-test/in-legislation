  "legislative_session": "2026",
  "identifier": "HB 1055",
  "title": "Municipal elections.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CITIES AND TOWNS; Generally",
    "ELECTIONS; Generally",
    "LOCAL ELECTED OFFICIALS; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Moves, as a general rule, elections of town officers to even-numbered years. Allows a town with a population of more than 10,000 to opt out of the general rule by resolution. Allows a city to pass a resolution to opt in to the general rule. Makes conforming changes."
    }
  ],

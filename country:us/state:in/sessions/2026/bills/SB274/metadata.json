  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that disannexation of certain property is effective upon filing a disannexation petition with the county auditor and recording the petition with the county recorder. Requires the property owner to file a petition requesting a municipality to annex the property not more than 48 months after the disannexation is effective."
    }
  ],

  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Establishes the Indiana emergency efficiency and resilience task force (task force). Provides that the task force shall study certain topics related to disaster resilience. Requires the task force to submit a written report with specific findings and recommendations to the legislative council not later than December 1, 2026."
    }
  ],

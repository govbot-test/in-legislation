  "identifier": "HB 1237",
  "title": "Use of opioid settlement funds.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ADDICTION SERVICES; Illicit Drugs, Prescription Drugs, Substances, and Alcohol",
    "CITIES AND TOWNS; Generally",
    "COUNTY GOVERNMENT",
    "HEALTH; Emergency Medical Services (EMS)",
    "TECHNOLOGY; Communication (Including Internet, Phone Lines, Print Media, Radio, and Television)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that distributions to the local abatement opioid settlement account to cities, counties, and towns may be used for the procurement of mobile radio equipment by a city, county, or town for use by first responders, in addition to programs of treatment, prevention, and care that are best practices as defined or required by a settlement document or court order under current law."
    }
  ],

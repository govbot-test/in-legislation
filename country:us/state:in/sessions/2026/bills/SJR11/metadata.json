  "subject": [
    "ELECTIONS; Public Questions and Referendums",
    "STATE GOVERNMENT; Constitution"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that the people of Indiana may propose and adopt amendments to the Constitution of the State of Indiana through an initiative. Provides that the people of Indiana may approve or reject any statute or part of any statute enacted by the general assembly through a referendum. This proposed amendment has not been previously agreed to by a general assembly."
    }
  ],

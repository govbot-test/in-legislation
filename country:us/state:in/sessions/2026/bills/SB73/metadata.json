{
  "legislative_session": "2026",
  "identifier": "SB 73",
  "title": "Masks at public assemblies.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CRIMINAL LAW AND PROCEDURE; Creation of New Offenses",
    "CRIMINAL LAW AND PROCEDURE; Offenses Against Persons",
    "HEALTH; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Makes wearing a mask at a public assembly a Class C misdemeanor, and increases the penalty to a Class A misdemeanor for a second or subsequent offense. Provides a defense under certain circumstances. Increases the penalty for rioting and disorderly conduct to a Level 6 felony if the offense is committed while wearing a mask."
    }
  ],

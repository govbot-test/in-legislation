  "subject": [
    "BOARDS, COMMISSIONS, AND COUNCILS; Generally",
    "GENERAL ASSEMBLY; Indiana Code",
    "LABOR AND EMPLOYMENT; Collective Bargaining, Benefits, and Wages",
    "SCHOOLS; Officers and Employees (Other than Teachers)",
    "SCHOOLS; Teachers"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Repeals the Hoosier alliance against drugs, the advisory committee on the oral history of the general assembly, and the Wendell L. Willkie memorial commission. Removes expired provisions located within Indiana Code sections. Limits collective bargaining with school bus drivers to the subjects allowed in collective bargaining with teachers. Provides that the prohibited subjects of collective bargaining with teachers apply to collective bargaining with school bus drivers. Makes conforming changes and technical corrections."
    }
  ],

    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Health (IDOH)",
    "ALCOHOL AND TOBACCO; Tobacco and Nicotine Products",
    "CHILDREN AND MINORS; Children in Need of Services (CHINS)",
    "CIVIL LAW AND PROCEDURE; Liabilities, Damages, and Penalties",
    "ENVIRONMENT; Hazardous Waste",
    "HEALTH CARE FACILITIES; Generally",
    "HEALTH CARE FACILITIES; Hospitals",
    "HEALTH CARE PROFESSIONALS; Pharmacists",
    "HEALTH; Behavioral Health; Mental Illness and Treatment",
    "HEALTH; Lead Testing",

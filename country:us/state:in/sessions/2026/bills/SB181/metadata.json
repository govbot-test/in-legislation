  "identifier": "SB 181",
  "title": "Notice of eviction.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CIVIL LAW AND PROCEDURE; Liabilities, Damages, and Penalties",
    "LOCAL GOVERNMENT; Generally",
    "PROPERTY; Generally",
    "PROPERTY; Housing",
    "PROPERTY; Landlords and Tenants"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires a landlord to provide notice at least five days before filing an eviction that includes the following: (1) The amount owed. (2) A calculation of late fees. (3) Acceptable methods of payment.  (4) The date the landlord intends to file an eviction if charges remain unpaid. Provides methods of written notice. Provides that notice is not required to terminate a lease if the landlord has met other notice requirements. Requires a landlord to complete required repairs issued by an eligible enforcement authority and meet standards required by a county health department. Repeals a provision concerning refusal or neglect to pay rent and corresponding notice requirements."
    }
  ],

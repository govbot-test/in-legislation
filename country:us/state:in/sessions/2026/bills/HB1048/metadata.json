{
  "legislative_session": "2026",
  "identifier": "HB 1048",
  "title": "VFD clothing and automobile allowances.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "FIREFIGHTERS; Fire Departments and Districts"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Increases, from $100 to $250, the clothing and automobile allowance for an active member of a volunteer fire department (department). Provides that a unit served by a volunteer fire department shall pay the clothing and automobile allowance directly to each active and participating member of the department."
    }
  ],

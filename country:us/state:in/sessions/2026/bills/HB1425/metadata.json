  "identifier": "HB 1425",
  "title": "Social service provider tax credit.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Revenue (DOR)",
    "BUSINESS ORGANIZATIONS AND ASSOCIATIONS; Charitable Organizations and Nonprofits",
    "SOCIAL SERVICES; Generally",
    "TAXES; Adjusted Gross Income Taxes",
    "TAXES; Credits"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows a qualified taxpayer to claim a credit against the taxpayer's state tax liability for designated contributions to qualified nonprofit organizations that provide: (1) comprehensive case management services for at risk families; (2) family support services; (3) in-school programs, community based events, or online resources to assist fathers in learning and improving parenting skills; or (4) programs that provide mutual support systems among mothers in raising children or information for mothers to enhance child development."
    }
  ],

  "identifier": "SB 141",
  "title": "Administration of do not call list.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CIVIL LAW AND PROCEDURE; Liabilities, Damages, and Penalties",
    "CIVIL LAW AND PROCEDURE; Statute of Limitations",
    "TECHNOLOGY; Communication (Including Internet, Phone Lines, Print Media, Radio, and Television)",
    "TRADE REGULATIONS; Consumer Credit and Consumer Protection (Including the Uniform Consumer Credit Code (UCCC))"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires a monthly listing of telephone numbers of Indiana consumers who request not to be solicited by telephone to be established, maintained, and published (current law requires a quarterly listing). Provides that certain actions may not be brought more than five years after the occurrence of the deceptive act (current law provides that the action may not be brought more than two years after the occurrence of the deceptive act). Makes conforming changes."
    }
  ],

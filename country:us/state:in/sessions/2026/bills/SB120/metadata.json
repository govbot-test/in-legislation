    "HIGHER EDUCATION; Athletics",
    "HIGHER EDUCATION; Colleges and Universities (Including Ivy Tech)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Prohibits a certificate holder or vendor from accepting a proposition bet from a collegiate athlete in the sport the collegiate athlete plays. Provides that the Indiana gaming commission may impose a civil penalty upon an individual who: (1) is a collegiate athlete; and (2) attempted to place or placed a proposition bet on a game in the sport that the individual plays."
    }
  ],

  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Authorizes the city of New Haven to impose an innkeeper's tax at a flat rate that does not exceed $5 per night. Amends provisions regarding distribution and uses of the Hamilton County innkeeper's tax. Makes corresponding changes to statutes concerning innkeeper's tax administration."
    }
  ],

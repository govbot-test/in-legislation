  "identifier": "HB 1025",
  "title": "County policies.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "LOCAL ELECTED OFFICIALS; Prosecutors",
    "PUBLIC DEFENDER; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Specifies that county residency requirements do not apply to: (1) public defenders (except for the chief public defender); (2) employees of a public defender office; (3) judicial officers; or (4) court personnel."
    }
  ],

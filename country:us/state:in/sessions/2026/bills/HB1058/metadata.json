  ],
  "subject": [
    "ANNEXATION OF TERRITORY",
    "TRANSPORTATION; Railroads, Trains, and Stations"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that annexation territory that is divided by railroad tracks satisfies contiguity requirements, if the territory on at least one side of the railroad tracks is contiguous to the municipality."
    }
  ],

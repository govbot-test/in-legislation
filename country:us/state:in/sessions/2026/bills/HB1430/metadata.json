  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows the legislative body of a county and certain cities to adopt a resolution to place a referendum on the ballot to impose a local preschool referendum tax levy (levy) to fund administration of a preschool program and provide tuition and other assistance. Allows a unit to impose a levy if approved by a majority of the voters. Provides that voters may not approve a levy that is imposed for more than eight years. Specifies procedures for the referendum. Provides that a unit that imposes a levy must establish a preschool education program and a local preschool education referendum tax levy fund."
    }
  ],

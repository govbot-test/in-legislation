  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the warden of the state prison to select an execution team consisting of members of the general assembly who have volunteered to serve on the execution team. Prohibits a person who is not a member of the general assembly from serving on an execution team, and provides that an execution may not be carried out until the execution team is fully staffed. Specifies that the name of a member of the general assembly who: (1) volunteers to serve on an execution team; or (2) serves on an execution team; is a public record."
    }
  ],

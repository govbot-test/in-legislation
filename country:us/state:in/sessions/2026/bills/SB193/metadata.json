  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that a governmental entity operating an activity on land leased by the governmental entity from the federal government is entitled to certain immunities from a tort claim. Expands the definition of \"extreme sport area\" to include an obstacle course."
    }

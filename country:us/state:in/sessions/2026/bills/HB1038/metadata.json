  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the Indiana gaming commission to accept applications and proposals to award an owner's license to operate a casino in Allen County if certain conditions are met. Requires a license fee for the owner's license to operate in Allen County in the amount of at least $50,000,000. Requires the fee for the Allen County casino license to be deposited in the state general fund."
    }
  ],

  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires certain drive-through facilities constructed or renovated after December 31, 2026, to have a separate bypass lane adjacent to the specified drive-through lanes. Makes certain exceptions. Requires the fire prevention and building safety commission to adopt administrative rules."
    }
  ],

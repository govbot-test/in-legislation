  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the Indiana department of transportation to take action necessary to construct one or more additional lanes of traffic across Indiana for: (1) eastbound; and (2) westbound; Interstate Highway 70 in areas of Interstate Highway 70 where there are four lanes of traffic. Makes an appropriation."
    }

{
  "legislative_session": "2026",
  "identifier": "SB 178",
  "title": "Payment of insurance claims.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "FINANCIAL SERVICES; Generally",
    "HEALTH; Billing and Costs",
    "INSURANCE; Health Insurance",
    "INSURANCE; Health Maintenance Organizations (HMOs)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that an insurer may not adjust a subsequent claim filed by a provider as a method of obtaining reimbursement of an overpayment made by the insurer on a prior claim by the provider. Provides that a health maintenance organization may not adjust a subsequent claim filed by a provider as a method of obtaining reimbursement of an overpayment made by the health maintenance organization on a prior claim by the provider. Provides that an insurer may not, more than one year after the date on which an overpayment on a provider claim was made to the provider by the insurer, request that the provider repay the overpayment (current law is two years). Provides that a health maintenance organization may not, more than one year after the date on which an overpayment on a provider claim was made to the provider by the health maintenance organization, request that the provider repay the overpayment (current law is two years). Makes conforming changes."
    }
  ],

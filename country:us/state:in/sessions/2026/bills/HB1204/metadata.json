{
  "legislative_session": "2026",
  "identifier": "HB 1204",
  "title": "Natural resource entrance fees.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Natural Resources (DNR)",
    "COUNTY GOVERNMENT",
    "LOCAL ELECTED OFFICIALS; Treasurers",
    "NATURAL RESOURCES; State Parks",
    "RECREATION AND ENTERTAINMENT"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows counties that meet certain criteria to adopt an ordinance to impose a surcharge of not more than $1 in addition to the fees charged by the department of natural resources (department) for entry into certain state parks and recreation areas. Provides that the surcharge may not be imposed on an annual state park pass holder. Requires the department to collect and to report and pay the surcharge to each county treasurer. Provides that the surcharge collected is to be used for certain purposes."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "SB 59",
  "title": "Notice of annexation outreach meetings.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ADVERTISEMENTS AND NOTICES",
    "ANNEXATION OF TERRITORY",
    "CITIES AND TOWNS; Generally",
    "COUNTY GOVERNMENT",
    "LOCAL GOVERNMENT; Generally",
    "ZONING AND PLANNING"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires a municipality to mail notice of the date, time, and location of annexation outreach meetings to: (1) the county executive of each county; (2) the township executive of each township; and (3) any plan commission; in which the annexation territory is located."
    }
  ],

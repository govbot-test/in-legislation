{
  "legislative_session": "2026",
  "identifier": "SB 263",
  "title": "Child and dependent care tax credit.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CHILDREN AND MINORS; Generally",
    "TAXES; Credits"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides a refundable child and dependent care tax credit to taxpayers whose adjusted gross income for the taxable year is not more than 250% of the federal poverty level. Provides that the credit is equal to the lesser of: (1) an amount ranging from $200 to $1,000, depending on the extent to which the taxpayer's adjusted gross income exceeds the federal poverty level; or (2) 20% of the taxpayer's employment related expenses."
    }
  ],

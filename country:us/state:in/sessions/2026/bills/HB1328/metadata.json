{
  "legislative_session": "2026",
  "identifier": "HB 1328",
  "title": "Charges for hospital administered drugs.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "HEALTH CARE FACILITIES; Hospitals",
    "HEALTH; Billing and Costs",
    "HEALTH; Prescription Drugs and Medications",
    "INSURANCE; Medicare"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Prohibits a hospital from billing for an administered drug an amount that exceeds the lesser of the following: (1) 120% of the Medicare reimbursement rate for the administered drug. (2) The amount the hospital bills for the administered drug on June 30, 2026. Creates an exception. Requires a hospital to update the Medicare reimbursement rate for an administered drug on January 1 and July 1 of each year."
    }
  ],

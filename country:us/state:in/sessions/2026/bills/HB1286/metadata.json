{
  "legislative_session": "2026",
  "identifier": "HB 1286",
  "title": "Military protective order.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ARMED FORCES; Servicemembers",
    "CIVIL LAW AND PROCEDURE; Evidence",
    "COURTS; Generally",
    "MARRIAGE AND FAMILY LAW; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Specifies that a party to a protective order proceeding has a duty to inform the court of any military protective orders issued by a military commander in effect between the parties. Allows the court to consider evidence of a military protective order in effect against a respondent for the protection of the petitioner. Amends provisions concerning facially valid foreign protection orders to include certain protection orders issued by a Canadian court."
    }
  ],

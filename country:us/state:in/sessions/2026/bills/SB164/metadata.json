{
  "legislative_session": "2026",
  "identifier": "SB 164",
  "title": "Study of community or urban microfarming.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Agriculture (ISDA)",
    "AGRICULTURE; Crops",
    "AGRICULTURE; Generally",
    "GENERAL ASSEMBLY; Generally",
    "HIGHER EDUCATION; Colleges and Universities (Including Ivy Tech)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the department of agriculture (department) to conduct a study to evaluate the feasibility of establishing community or urban microfarm zones statewide. Requires the department to submit a report to the general assembly containing certain findings and recommendations not later than December 1, 2027."
    }
  ],

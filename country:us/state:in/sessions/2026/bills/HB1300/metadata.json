  "identifier": "HB 1300",
  "title": "Deferred retirement option plan.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "PENSIONS AND RETIREMENT BENEFITS; Public Retirement System (INPRS)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows a member of the 1925 police pension fund, 1937 firefighters' pension fund, 1953 police pension fund (Indianapolis), or 1977 police officers' and firefighters' pension and disability fund to withdraw from the deferred retirement option plan (DROP) and make an election to enter the DROP for a second time not earlier than three years after the date the member withdraws from the DROP. Provides that a member may make an election to enter the DROP only twice in the member's lifetime."
    }
  ],

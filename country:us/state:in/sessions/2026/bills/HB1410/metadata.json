  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that, on or before July 1, 2027, the law enforcement training board shall establish a program to allow a law enforcement officer who has successfully completed the Tier II basic training requirement to subsequently complete the additional Tier I basic training requirements."
    }

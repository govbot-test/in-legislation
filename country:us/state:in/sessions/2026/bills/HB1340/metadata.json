  "identifier": "HB 1340",
  "title": "Sales tax exemption for utility service.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "NATURAL RESOURCES; Natural Gases and Carbon Dioxide",
    "TAXES; Sales and Use Taxes",
    "UTILITIES; Electric",

  "legislative_session": "2026",
  "identifier": "SB 158",
  "title": "Lake County rounding of local taxes pilot program.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "COUNTIES; Lake",
    "LOCAL GOVERNMENT; Generally",
    "TAXES; Local Income Taxes"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Establishes the Lake County rounding of local taxes pilot program. Requires a local unit to round a tax amount payable to the local unit: (1) downward in the case of a tax amount with one, two, six, or seven in the second decimal place to the next amount divisible by $0.05; or (2) upward in the case of a tax amount with three, four, eight, or nine in the second decimal place to the next amount divisible by $0.05."
    }
  ],

  "subject": [
    "BOARDS, COMMISSIONS, AND COUNCILS; Newly Created",
    "GENERAL ASSEMBLY; Legislative Council",
    "PROPERTY; Landlords and Tenants"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Establishes the access to counsel in eviction task force (task force) to review matters related to the eviction process and potential funding sources to increase a tenant's access to counsel in an eviction proceeding. Sets forth membership, and requires the task force to issue a report to the legislative council. Provides that the task force expires December 31, 2026."
    }
  ],

  "identifier": "SB 10",
  "title": "State employee retirement benefits.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Public Retirement System (INPRS)",
    "AGENCIES; State Budget Agency (SBA)",
    "LABOR AND EMPLOYMENT; Collective Bargaining, Benefits, and Wages",
    "PENSIONS AND RETIREMENT BENEFITS; Public Retirement System (INPRS)",
    "PENSIONS AND RETIREMENT BENEFITS; Public Retirement System (INPRS)",

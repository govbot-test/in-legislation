{
  "legislative_session": "2026",
  "identifier": "HB 1135",
  "title": "Investor ownership of single family residences.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "FINANCIAL SERVICES; Loans and Mortgages",
    "TAXES; Excise Taxes (Not Including Vehicles)",
    "TAXES; Generally"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Establishes the housing down payment assistance fund. Establishes a transfer tax equal to 50% of the fair market value of a single family residence for each single family residence acquired by an applicable taxpayer after the applicable date. Establishes a maximum number of single family residences that may be owned by an applicable taxpayer after the applicable date for purposes of calculating an annual excise tax on any excess single family residences."
    }
  ],

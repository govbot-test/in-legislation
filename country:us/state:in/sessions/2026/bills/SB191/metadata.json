  "identifier": "SB 191",
  "title": "Electronic record of confidential address.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CIVIL LAW AND PROCEDURE; Contracts and Legal Documents",
    "CIVIL LAW AND PROCEDURE; Generally",
    "LOCAL ELECTED OFFICIALS; Recorders"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Exempts a county recorder from the requirement of accepting an electronic document for recording if the electronic document contains identifying information of a person in the address confidentiality program."
    }
  ],

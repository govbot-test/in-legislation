  "identifier": "SB 187",
  "title": "Regional sewer districts.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "BOARDS, COMMISSIONS, AND COUNCILS; Generally",
    "COUNTY GOVERNMENT",
    "ENVIRONMENT; Sewage and Sewage Systems",
    "ENVIRONMENT; Solid Waste and Trash",
    "ENVIRONMENT; Water Pollution",
    "GENERAL ASSEMBLY; Legislative Council",
    "LOCAL GOVERNMENT; Generally",

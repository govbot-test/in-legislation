  ],
  "subject": [
    "CRIMINAL LAW AND PROCEDURE; Creation of New Offenses",
    "CRIMINAL LAW AND PROCEDURE; Motor Vehicle Offenses (Excluding Traffic Violations)",
    "TECHNOLOGY; Communication (Including Internet, Phone Lines, Print Media, Radio, and Television)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that a person who knowingly or intentionally violates the statute prohibiting use of a telecommunications device while operating a moving motor vehicle commits a Level 5 felony if the violation is the proximate cause of serious bodily injury to another person."
    }
  ],

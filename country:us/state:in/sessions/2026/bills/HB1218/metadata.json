  "identifier": "HB 1218",
  "title": "Straight ticket voting.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ELECTIONS; Political Parties"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Removes a voter's option to vote for all candidates of a political party or an independent ticket at one time (straight ticket voting) in a general or municipal election. Repeals superseded statutes relating to straight ticket voting."
    }
  ],

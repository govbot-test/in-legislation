  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that 10% of the excess property tax proceeds collected in an allocation area must be allocated among school corporations, libraries, and taxing units that provide police services, fire protection, emergency medical service, or public safety services in the allocation area."

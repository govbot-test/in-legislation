  "identifier": "HB 1133",
  "title": "Elimination of straight ticket voting.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ELECTIONS; Conducting Elections (Excluding Recounts)",
    "ELECTIONS; Political Parties",

  "identifier": "HB 1189",
  "title": "Labor requirements for data center incentives.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "LABOR AND EMPLOYMENT; Unions",
    "TECHNOLOGY; Computers, Cell Phones, and Devices",

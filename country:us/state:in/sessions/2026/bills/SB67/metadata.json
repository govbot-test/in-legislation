  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires the department of natural resources to study and issue a report on the following topics: (1) opportunities to leverage public land to improve public health outcomes; (2) options for a consistent visitor fee collection system at state fish and wildlife areas; and (3) a plan to mitigate and recover from natural disasters affecting public land."
    }
  ],

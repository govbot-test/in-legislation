{
  "legislative_session": "2026",
  "identifier": "HB 1269",
  "title": "Unlawful proposition penalties.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CRIMINAL LAW AND PROCEDURE; Human Trafficking",
    "CRIMINAL LAW AND PROCEDURE; Sentencing",
    "CRIMINAL LAW AND PROCEDURE; Sex Offenses",
    "LOCAL ELECTED OFFICIALS; Auditors"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that at the time of sentencing for a person convicted of making an unlawful proposition the court may require the person to complete a prostitution offender program approved by the court. Requires a person ordered to complete a prostitution offender program to pay a fee."
    }
  ],

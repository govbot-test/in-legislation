  ],
  "subject": [
    "COUNTY GOVERNMENT",
    "TOWNSHIPS AND TOWNSHIP OFFICERS"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Abolishes the office of township assessor, in counties in which the office of township assessor has not already been abolished, if the county council and county commissioners unanimously vote to abolish the office and consolidate it with the office of the county assessor."
    }

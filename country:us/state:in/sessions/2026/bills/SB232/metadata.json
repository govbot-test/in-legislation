{
  "legislative_session": "2026",
  "identifier": "SB 232",
  "title": "Real property appraisals.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CITIES; Gary",
    "LOCAL GOVERNMENT; Contracts, Procurements, and Purchases",
    "PROPERTY; Generally",
    "PROPERTY; Housing",
    "PROPERTY; Real Estate",
    "REAL ESTATE APPRAISERS, BROKERS, AND SALESPERSONS"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Allows the city of Gary to hire an appraiser to conduct appraisals of residential and commercial properties to assist the city with disposing of the city's real property. Prohibits an employee or appointed or elected official of the city from purchasing property that is appraised by the appraiser."
    }
  ],

  "identifier": "SB 262",
  "title": "INSPECT program.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Department of Health (IDOH)",
    "AGENCIES; Family and Social Services Administration (FSSA)",
    "AGENCIES; Professional Licensing Agency (PLA)",
    "HEALTH CARE FACILITIES; Pharmacies",
    "HEALTH CARE PROFESSIONALS; Pharmacists",
    "HEALTH; Prescription Drugs and Medications"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Sets forth the circumstances in which a dispenser is not required to transmit certain information to the INSPECT program (program). Requires an opioid treatment program to, before reporting patient information to the program, comply with federal regulations in obtaining patient consent. Allows the board of pharmacy to disclose prescription drug monitoring program data to a representative of the Indiana department of health and the office of the secretary of family and social services for specified purposes."
    }
  ],

  ],
  "subject": [
    "REAL ESTATE APPRAISERS, BROKERS, AND SALESPERSONS"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Requires a broker company who refers a client or customer to another broker company to disclose if the broker company may be compensated for referring the client or customer."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "HB 1131",
  "title": "Licensed estheticians and electrologists.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AGENCIES; Professional Licensing Agency (PLA)"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Amends the definition of \"esthetician\" to include certain services. Adds a definition for \"microneedling\". Requires a person who provides microneedling to provide the professional licensing agency proof of advanced training or certification at the agency's request. Provides that an applicant for an electrologist license does not need to hold a cosmetologist license or esthetician license before applying for an electrologist license. Requires an applicant to complete a combined total of 600 hours of education and experience required under the rules adopted by the state board of cosmetology and barber examiners (board) beginning July 1, 2027. Requires the board to amend the rules for electrology training in a beauty culture school not later than June 30, 2027."
    }
  ],

{
  "legislative_session": "2026",
  "identifier": "SB 288",
  "title": "Organ donation.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DEATH AND DECEASED; Anatomical Gifts and Organ Donation",
    "LABOR AND EMPLOYMENT; Collective Bargaining, Benefits, and Wages"
  ],
  "abstracts": [
    {
      "note": "Digest",
      "abstract": "Provides that an employee who has worked for an employer for at least a year is entitled to take an unpaid leave of absence for organ donation. Provides that a leave of absence may not exceed 30 working days per calendar year. Requires an eligible employee to provide notice to the employee's employer before taking a leave of absence. Provides that an employer may require an eligible employee to take other leave before using the leave of absence."
    }
  ],
